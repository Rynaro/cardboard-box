{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rynaro/Vivi/blob/v1.1.0/schemas/spec-profile.v1.json",
  "title": "ECL spec profile v1",
  "description": "Vendored from eidolons-ecl/schemas/per-eidolon/spec.v1.json (ECL v1.0.0). Inbound verification: SPECTRA-emitted specification received by Vivi. Contract: spectra-to-vivi.yaml.",
  "allOf": [
    { "$ref": "_base-profile.v1.json" },
    {
      "type": "object",
      "required": ["target_repos", "stories_count", "validation_gates_count"],
      "properties": {
        "kind":    { "const": "spec" },
        "eidolon": { "const": "spectra" },
        "target_repos": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Repos the spec applies to."
        },
        "stories_count":          { "type": "integer", "minimum": 0 },
        "validation_gates_count": { "type": "integer", "minimum": 0 },
        "confidence":             { "type": "number",  "minimum": 0, "maximum": 1 },
        "decisions_resolved_at":  { "type": "string",  "format": "date-time" }
      }
    }
  ]
}
