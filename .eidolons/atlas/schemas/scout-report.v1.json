{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.agent/schemas/scout-report.v1.json",
  "title": "ATLAS Scout Report",
  "description": "The final artifact from Phase S. What downstream agents consume.",
  "type": "object",
  "required": [
    "mission_recap", "topology_summary", "answer", "recommended_actions",
    "risks_and_gaps", "telemetry", "handoff"
  ],
  "properties": {
    "mission_recap": {
      "type": "object",
      "required": ["mission_id", "goal", "decision_target", "scope", "status"],
      "properties": {
        "mission_id": {"type": "string", "pattern": "^[0-9]{8}-[0-9]{3}$"},
        "goal": {"type": "string"},
        "decision_target": {"type": "string"},
        "scope": {
          "type": "object",
          "properties": {
            "include": {"type": "array", "items": {"type": "string"}},
            "exclude": {"type": "array", "items": {"type": "string"}}
          }
        },
        "status": {
          "type": "string",
          "enum": ["completed", "partial", "blocked"]
        }
      }
    },
    "topology_summary": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["fact", "path"],
        "properties": {
          "fact": {"type": "string", "maxLength": 300},
          "path": {"type": "string"},
          "finding_refs": {
            "type": "array",
            "items": {"type": "string", "pattern": "^FINDING-[0-9]+$|^GAP-[0-9]+$"}
          }
        }
      }
    },
    "answer": {
      "type": "array",
      "minItems": 1,
      "description": "One entry per DT-N sub-question. Prose with embedded FINDING refs.",
      "items": {
        "type": "object",
        "required": ["sub_question_id", "prose", "finding_refs"],
        "properties": {
          "sub_question_id": {"type": "string", "pattern": "^DT-[0-9]+$"},
          "prose": {
            "type": "string",
            "minLength": 10,
            "maxLength": 2000
          },
          "finding_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "pattern": "^FINDING-[0-9]+$|^GAP-[0-9]+$"}
          }
        }
      }
    },
    "recommended_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "priority", "recipient", "description", "references"],
        "properties": {
          "id": {"type": "string", "pattern": "^R-[0-9]+$"},
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "recipient": {
            "type": "string",
            "enum": ["SPECTRA", "APIVR-Delta", "ATLAS", "human", "hiram", "veronica", "archie", "reggie"]
          },
          "description": {
            "type": "string",
            "minLength": 10,
            "maxLength": 800
          },
          "references": {
            "type": "array",
            "items": {"type": "string", "pattern": "^FINDING-[0-9]+$|^GAP-[0-9]+$"}
          },
          "timebox": {
            "type": "string",
            "pattern": "^up to [0-9.]+ (hours?|days?|weeks?)$",
            "description": "ElectionBuddy convention: 'up to N days' framing"
          }
        }
      }
    },
    "risks_and_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "tier"],
        "properties": {
          "id": {"type": "string", "pattern": "^GAP-[0-9]+$|^RISK-[0-9]+$"},
          "description": {"type": "string"},
          "tier": {"type": "string", "enum": ["H", "M", "L"]},
          "proposed_mitigation": {"type": "string"}
        }
      }
    },
    "integrity_checklist": {
      "type": "object",
      "description": "MANDATORY when hard_gate=true (Reggie election-critical missions). Omit otherwise.",
      "properties": {
        "cvr_writes_append_only": {"$ref": "#/$defs/checklist_item"},
        "integer_only_arithmetic": {"$ref": "#/$defs/checklist_item"},
        "authorization_present": {"$ref": "#/$defs/checklist_item"},
        "pii_cvr_boundary_preserved": {"$ref": "#/$defs/checklist_item"},
        "psepho_inputs_stateless": {"$ref": "#/$defs/checklist_item"},
        "human_signoff_recipient": {"$ref": "#/$defs/checklist_item"}
      }
    },
    "telemetry": {
      "type": "object",
      "required": ["phases", "fold_ratio", "search_efficiency"],
      "properties": {
        "phases": {
          "type": "object",
          "properties": {
            "assess": {"$ref": "#/$defs/phase_telemetry"},
            "traverse": {"$ref": "#/$defs/phase_telemetry"},
            "locate": {"$ref": "#/$defs/phase_telemetry"},
            "abstract": {"$ref": "#/$defs/phase_telemetry"},
            "synthesize": {"$ref": "#/$defs/phase_telemetry"}
          }
        },
        "fold_ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "search_efficiency": {"type": "number", "minimum": 0, "maximum": 1},
        "hard_gate_active": {"type": "boolean"},
        "cvr_mutation_paths_detected": {
          "type": "object",
          "properties": {
            "insert_only": {"type": "integer", "minimum": 0},
            "update": {"type": "integer", "minimum": 0},
            "delete": {"type": "integer", "minimum": 0},
            "raw_sql": {"type": "integer", "minimum": 0}
          }
        },
        "pii_boundary_crossings_flagged": {"type": "integer", "minimum": 0},
        "psepho_touches": {"type": "integer", "minimum": 0},
        "degraded_toolchain": {"type": "boolean"}
      }
    },
    "handoff": {
      "type": "object",
      "required": ["primary_recipient", "report_path"],
      "properties": {
        "primary_recipient": {
          "type": "string",
          "enum": ["SPECTRA", "APIVR-Delta", "human", "hiram", "veronica", "archie"]
        },
        "fallback_recipient": {
          "type": "string",
          "enum": ["human"]
        },
        "report_path": {"type": "string"},
        "memex_root": {"type": "string"},
        "critical_gaps": {
          "type": "array",
          "items": {"type": "string", "pattern": "^GAP-[0-9]+$"}
        },
        "open_questions": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  },
  "$defs": {
    "checklist_item": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["verified", "violated", "unverified"]
        },
        "finding_ref": {
          "type": "string",
          "pattern": "^FINDING-[0-9]+$|^GAP-[0-9]+$"
        },
        "note": {"type": "string"}
      }
    },
    "phase_telemetry": {
      "type": "object",
      "properties": {
        "tokens_in": {"type": "integer", "minimum": 0},
        "tokens_out": {"type": "integer", "minimum": 0},
        "tool_calls": {"type": "integer", "minimum": 0},
        "wall_clock_s": {"type": "integer", "minimum": 0}
      }
    }
  }
}
